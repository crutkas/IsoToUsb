<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="IsoToUsb.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:IsoToUsb"
    xmlns:viewmodels="using:IsoToUsb.ViewModels"
    xmlns:services="using:IsoToUsb.Services"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <!-- Concept A v2 · Twin floating cards (Setup · Work):
         Row 0 (*):    two floating cards (Setup on the left, Work on the right).
                       Elevation/focus shifts by state: IsSetupFocal when idle so
                       the user looks at inputs; IsWorkFocal during/after a build
                       so the user looks at the pipeline rail and log.
                       The Work card unifies the phase rail (left edge) and the
                       live log (rest) into one surface — they belong together.
         Row 1 (72 px): bottom action bar — status pill + progress + Refresh/Cancel/
                        Start, plus a caption row (elevation, current op, version).
                        The status pill is the single source of truth for "Build
                        complete"; there is intentionally no result InfoBar inside
                        the Setup card. -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="72" />
        </Grid.RowDefinitions>

        <!-- ======================== TWIN FLOATING CARDS ======================== -->
        <Grid Grid.Row="0" Padding="14" ColumnSpacing="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ====== LEFT · SETUP CARD ====== -->
            <Border
                Grid.Column="0"
                CornerRadius="12"
                BorderThickness="1"
                Background="{x:Bind ViewModel.IsSetupFocal, Mode=OneWay, Converter={StaticResource BoolToFocalBackgroundConverter}}"
                BorderBrush="{x:Bind ViewModel.IsSetupFocal, Mode=OneWay, Converter={StaticResource BoolToFocalBorderBrushConverter}}"
                Opacity="{x:Bind ViewModel.IsSetupFocal, Mode=OneWay, Converter={StaticResource BoolToFocalOpacityConverter}}">
                <Grid Padding="18" RowSpacing="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Section: Source ISO -->
                    <StackPanel Grid.Row="0" Spacing="6">
                        <TextBlock
                            Text="SOURCE ISO"
                            FontSize="11"
                            FontWeight="SemiBold"
                            CharacterSpacing="60"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <Border
                            x:Name="DropTarget"
                            AllowDrop="True"
                            BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                            BorderThickness="1.5"
                            CornerRadius="8"
                            Padding="14"
                            MinHeight="98"
                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                            DragOver="OnDropTargetDragOver"
                            Drop="OnDropTargetDrop">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
                                <FontIcon Glyph="&#xE7C3;" FontSize="22" HorizontalAlignment="Center" />
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    Text="{x:Bind ViewModel.IsoPath, Mode=OneWay, TargetNullValue='Drop a Windows ISO here'}"
                                    TextTrimming="CharacterEllipsis"
                                    TextWrapping="NoWrap" />
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontSize="11"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="or use Browse · drop another to replace" />
                                <Button
                                    HorizontalAlignment="Center"
                                    Margin="0,4,0,0"
                                    Content="Browse..."
                                    IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource NotConverter}}"
                                    Click="OnBrowseClicked" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Section: Target USB -->
                    <StackPanel Grid.Row="1" Spacing="6">
                        <TextBlock
                            Text="TARGET USB"
                            FontSize="11"
                            FontWeight="SemiBold"
                            CharacterSpacing="60"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <ComboBox
                            HorizontalAlignment="Stretch"
                            ItemsSource="{x:Bind ViewModel.Drives, Mode=OneWay}"
                            SelectedItem="{x:Bind ViewModel.SelectedDrive, Mode=TwoWay}"
                            IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource NotConverter}}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="services:DiskInfo">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE88E;" FontSize="14" />
                                        <TextBlock>
                                            <Run Text="Disk" />
                                            <Run Text="{x:Bind Number}" />
                                            <Run Text="{x:Bind DriveLettersTag}" />
                                            <Run Text=" — " />
                                            <Run Text="{x:Bind FriendlyName}" />
                                            <Run Text=" (" />
                                            <Run Text="{x:Bind SizeDisplay}" />
                                            <Run Text=")" />
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <!-- Section: defaults reminder -->
                    <StackPanel Grid.Row="2" Spacing="6">
                        <TextBlock
                            Text="DEFAULTS"
                            FontSize="11"
                            FontWeight="SemiBold"
                            CharacterSpacing="60"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <Grid ColumnSpacing="8" RowSpacing="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Boot mode" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="UEFI" FontSize="12" FontWeight="SemiBold" />
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Partition scheme" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="GPT" FontSize="12" FontWeight="SemiBold" />
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="File system" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="FAT32" FontSize="12" FontWeight="SemiBold" />
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Auto-split install.wim" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="On" FontSize="12" FontWeight="SemiBold" />
                        </Grid>
                    </StackPanel>

                    <!-- Spacer row pushes the footer badge to the bottom -->
                    <Border Grid.Row="3" />

                    <!-- Setup footer badge — replaces the old result InfoBar.
                         Tracks SetupFooterText/SetupFooterGlyph; the bottom action
                         bar's status pill is the canonical "Build complete" channel. -->
                    <Border
                        Grid.Row="4"
                        MinHeight="46"
                        VerticalAlignment="Bottom"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="10"
                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <FontIcon
                                Glyph="{x:Bind ViewModel.SetupFooterGlyph, Mode=OneWay}"
                                FontSize="14"
                                VerticalAlignment="Top"
                                Margin="0,2,0,0"
                                Foreground="{x:Bind ViewModel.Status, Mode=OneWay, Converter={StaticResource StatusKindToBrushConverter}, ConverterParameter=foreground}" />
                            <TextBlock
                                FontSize="12"
                                TextWrapping="Wrap"
                                VerticalAlignment="Center"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="{x:Bind ViewModel.SetupFooterText, Mode=OneWay}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- ====== RIGHT · WORK CARD (phase rail + log) ====== -->
            <Border
                Grid.Column="1"
                CornerRadius="12"
                BorderThickness="1"
                Background="{x:Bind ViewModel.IsWorkFocal, Mode=OneWay, Converter={StaticResource BoolToFocalBackgroundConverter}}"
                BorderBrush="{x:Bind ViewModel.IsWorkFocal, Mode=OneWay, Converter={StaticResource BoolToFocalBorderBrushConverter}}"
                Opacity="{x:Bind ViewModel.IsWorkFocal, Mode=OneWay, Converter={StaticResource BoolToFocalOpacityConverter}}">
                <Grid ColumnSpacing="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="86" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Phase rail (left edge of the Work card) -->
                    <Border
                        Grid.Column="0"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="0,0,1,0"
                        Padding="10,16,10,16">
                        <ItemsControl ItemsSource="{x:Bind ViewModel.Phases, Mode=OneWay}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel
                                        Orientation="Vertical"
                                        Spacing="14"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Stretch" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="viewmodels:PhaseItem">
                                    <StackPanel
                                        Orientation="Vertical"
                                        Spacing="4"
                                        HorizontalAlignment="Center"
                                        ToolTipService.ToolTip="{x:Bind Name}">
                                        <!-- Rail node: 32px circle. Icon stays the same
                                             across statuses; colours change to communicate
                                             pending / running / done. ProgressRing overlays
                                             the icon only while running. -->
                                        <Grid
                                            Width="34"
                                            Height="34"
                                            HorizontalAlignment="Center">
                                            <Border
                                                Width="34"
                                                Height="34"
                                                CornerRadius="17"
                                                BorderThickness="1"
                                                Background="{x:Bind Status, Mode=OneWay, Converter={StaticResource PhaseStatusToRailBrushConverter}, ConverterParameter=node-background}"
                                                BorderBrush="{x:Bind Status, Mode=OneWay, Converter={StaticResource PhaseStatusToRailBrushConverter}, ConverterParameter=node-border}" />
                                            <FontIcon
                                                FontSize="15"
                                                Glyph="{x:Bind RailGlyph}"
                                                Foreground="{x:Bind Status, Mode=OneWay, Converter={StaticResource PhaseStatusToRailBrushConverter}, ConverterParameter=node-foreground}"
                                                Visibility="{x:Bind IsRunning, Mode=OneWay, Converter={StaticResource InvertedBoolToVisibilityConverter}}" />
                                            <ProgressRing
                                                Width="22"
                                                Height="22"
                                                IsActive="{x:Bind IsRunning, Mode=OneWay}"
                                                Visibility="{x:Bind IsRunning, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                                        </Grid>
                                        <TextBlock
                                            Text="{x:Bind ShortName}"
                                            FontSize="10"
                                            FontWeight="SemiBold"
                                            HorizontalAlignment="Center"
                                            TextAlignment="Center"
                                            Foreground="{x:Bind Status, Mode=OneWay, Converter={StaticResource PhaseStatusToRailBrushConverter}, ConverterParameter=label-foreground}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>

                    <!-- Log column -->
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="38" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Log header strip -->
                        <Border
                            Grid.Row="0"
                            Padding="16,0"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="0,0,0,1"
                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                            <StackPanel
                                Orientation="Horizontal"
                                Spacing="10"
                                VerticalAlignment="Center">
                                <FontIcon
                                    Glyph="&#xE756;"
                                    FontSize="13"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock
                                    Text="Log"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    VerticalAlignment="Center" />
                                <TextBlock
                                    Text="·"
                                    FontSize="12"
                                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                    VerticalAlignment="Center" />
                                <TextBlock
                                    Text="{x:Bind ViewModel.StatusPillText, Mode=OneWay}"
                                    FontSize="12"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <!-- Log content: monospaced, syntax-coloured, auto-scrolling -->
                        <ScrollViewer
                            Grid.Row="1"
                            x:Name="LogScrollViewer"
                            Padding="16,12"
                            VerticalScrollMode="Auto"
                            VerticalScrollBarVisibility="Auto"
                            HorizontalScrollMode="Disabled"
                            HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{x:Bind ViewModel.LogLines, Mode=OneWay}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="viewmodels:LogLine">
                                        <TextBlock
                                            FontFamily="Consolas"
                                            FontSize="12"
                                            LineHeight="18"
                                            TextWrapping="Wrap"
                                            Foreground="{ThemeResource TextFillColorPrimaryBrush}">
                                            <Run
                                                Text="{x:Bind Timestamp}"
                                                Foreground="{ThemeResource LogTimestampBrush}" />
                                            <Run
                                                Text="{x:Bind Keyword}"
                                                FontWeight="SemiBold"
                                                Foreground="{x:Bind Severity, Converter={StaticResource LogSeverityToBrushConverter}}" />
                                            <Run Text="{x:Bind Rest}" />
                                        </TextBlock>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- ======================== BOTTOM ACTION BAR ======================== -->
        <Border
            Grid.Row="1"
            BorderBrush="{ThemeResource ControlStrongStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <Grid Padding="18,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Row 0: action controls (status pill, progress, buttons) -->
                <Grid ColumnSpacing="12" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Status pill: canonical "Build complete" channel. -->
                    <Border
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        Padding="10,3"
                        CornerRadius="10"
                        BorderThickness="1"
                        Background="{x:Bind ViewModel.Status, Mode=OneWay, Converter={StaticResource StatusKindToBrushConverter}, ConverterParameter=background}"
                        BorderBrush="{x:Bind ViewModel.Status, Mode=OneWay, Converter={StaticResource StatusKindToBrushConverter}, ConverterParameter=border}">
                        <TextBlock
                            FontSize="12"
                            FontWeight="SemiBold"
                            Text="{x:Bind ViewModel.StatusPillText, Mode=OneWay}"
                            Foreground="{x:Bind ViewModel.Status, Mode=OneWay, Converter={StaticResource StatusKindToBrushConverter}, ConverterParameter=foreground}" />
                    </Border>

                    <ProgressBar
                        Grid.Column="1"
                        Height="6"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Center"
                        Margin="14,0"
                        Minimum="0"
                        Maximum="100"
                        Value="{x:Bind ViewModel.ProgressPercent, Mode=OneWay}"
                        ShowError="False"
                        IsIndeterminate="False" />

                    <StackPanel
                        Grid.Column="2"
                        Orientation="Horizontal"
                        Spacing="8"
                        VerticalAlignment="Center">
                        <Button
                            ToolTipService.ToolTip="Refresh drive list"
                            IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource NotConverter}}"
                            Command="{x:Bind ViewModel.RefreshDrivesCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE72C;" FontSize="13" />
                                <TextBlock Text="Refresh" FontSize="13" />
                            </StackPanel>
                        </Button>
                        <Button
                            Content="Cancel"
                            Command="{x:Bind ViewModel.CancelCommand}"
                            IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay}" />
                        <Button
                            Style="{StaticResource AccentButtonStyle}"
                            Command="{x:Bind ViewModel.StartCommand}"
                            IsEnabled="{x:Bind ViewModel.CanStart, Mode=OneWay}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE768;" FontSize="13" />
                                <TextBlock Text="Start build" FontSize="13" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Row 1: caption strip (elevation, current op, version) -->
                <Grid Grid.Row="1" ColumnSpacing="10" Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <FontIcon
                            Glyph="&#xE730;"
                            FontSize="11"
                            Foreground="{x:Bind ViewModel.Status, Mode=OneWay, Converter={StaticResource StatusKindToBrushConverter}, ConverterParameter=foreground}" />
                        <TextBlock
                            Text="Elevated worker"
                            FontSize="11"
                            VerticalAlignment="Center"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>

                    <TextBlock
                        Grid.Column="1"
                        Text="·"
                        FontSize="11"
                        VerticalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorTertiaryBrush}" />

                    <TextBlock
                        Grid.Column="2"
                        Text="{x:Bind ViewModel.CurrentOperation, Mode=OneWay}"
                        FontSize="11"
                        VerticalAlignment="Center"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="NoWrap"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                    <TextBlock
                        Grid.Column="3"
                        Text="IsoToUsb · MIT · runs as administrator"
                        FontSize="11"
                        VerticalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Page>
