<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="IsoToUsb.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:IsoToUsb"
    xmlns:conv="using:IsoToUsb.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Per-theme brushes for log keyword colouring; LogSeverityToBrushConverter
                 looks these up by key so light/dark switches Just Work. -->
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="LogActionBrush"     Color="#107C10" />
                    <SolidColorBrush x:Key="LogWarnBrush"       Color="#946F00" />
                    <SolidColorBrush x:Key="LogErrorBrush"      Color="#C42B1C" />
                    <SolidColorBrush x:Key="LogTimestampBrush"  Color="#8A8A8A" />
                    <!-- Page background. Matches design/elevation-a-v2.html's
                         board-bg #ECECEC so cards (which use the lighter
                         CardBackgroundFillColorDefaultBrush ~#FBFBFB) read as
                         elevated above the page instead of being lost in it. -->
                    <SolidColorBrush x:Key="AppPageBackgroundBrush" Color="#ECECEC" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="LogActionBrush"     Color="#6CCB5F" />
                    <SolidColorBrush x:Key="LogWarnBrush"       Color="#FCE100" />
                    <SolidColorBrush x:Key="LogErrorBrush"      Color="#FF99A4" />
                    <SolidColorBrush x:Key="LogTimestampBrush"  Color="#9A9A9A" />
                    <SolidColorBrush x:Key="AppPageBackgroundBrush" Color="#161616" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="HighContrast">
                    <SolidColorBrush x:Key="LogActionBrush"     Color="{ThemeResource SystemColorWindowTextColor}" />
                    <SolidColorBrush x:Key="LogWarnBrush"       Color="{ThemeResource SystemColorHighlightColor}" />
                    <SolidColorBrush x:Key="LogErrorBrush"      Color="{ThemeResource SystemColorHotlightColor}" />
                    <SolidColorBrush x:Key="LogTimestampBrush"  Color="{ThemeResource SystemColorGrayTextColor}" />
                    <SolidColorBrush x:Key="AppPageBackgroundBrush" Color="{ThemeResource SystemColorWindowColor}" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <conv:NotConverter x:Key="NotConverter" />
            <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <conv:InvertedBoolToVisibilityConverter x:Key="InvertedBoolToVisibilityConverter" />
            <conv:NullToCollapsedConverter x:Key="NullToCollapsedConverter" />
            <conv:PhaseStatusToBrushConverter x:Key="PhaseStatusToBrushConverter" />
            <conv:PhaseStatusToTitleBrushConverter x:Key="PhaseStatusToTitleBrushConverter" />
            <conv:StatusKindToBrushConverter x:Key="StatusKindToBrushConverter" />
            <conv:LogSeverityToBrushConverter x:Key="LogSeverityToBrushConverter" />
            <conv:BoolToFocalOpacityConverter x:Key="BoolToFocalOpacityConverter" />
            <conv:BoolToFocalTranslationConverter x:Key="BoolToFocalTranslationConverter" />
            <conv:BoolToFocalBorderBrushConverter x:Key="BoolToFocalBorderBrushConverter" />
            <conv:BoolToFocalBackgroundConverter x:Key="BoolToFocalBackgroundConverter" />
            <conv:PhaseStatusToRailBrushConverter x:Key="PhaseStatusToRailBrushConverter" />

            <!-- Soft 5px accent ring drawn behind the active rail node.
                 Mirrors the design board's
                 box-shadow:0 0 0 5px color-mix(accent 10%, transparent). -->
            <SolidColorBrush x:Key="RailActiveGlowBrush" Color="{ThemeResource SystemAccentColor}" Opacity="0.16" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
