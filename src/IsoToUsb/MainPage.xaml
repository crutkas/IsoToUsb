<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="IsoToUsb.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:IsoToUsb"
    xmlns:services="using:IsoToUsb.Services"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            x:Name="DropTarget"
            AllowDrop="True"
            BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
            BorderThickness="2"
            CornerRadius="8"
            Padding="24"
            MinHeight="120"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            DragOver="OnDropTargetDragOver"
            Drop="OnDropTargetDrop">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                <FontIcon Glyph="&#xE7C3;" FontSize="32" HorizontalAlignment="Center" />
                <TextBlock
                    Style="{StaticResource SubtitleTextBlockStyle}"
                    HorizontalAlignment="Center"
                    Text="Drop a Windows ISO here" />
                <TextBlock
                    Style="{StaticResource CaptionTextBlockStyle}"
                    HorizontalAlignment="Center"
                    Text="{x:Bind ViewModel.IsoPath, Mode=OneWay, TargetNullValue='(no ISO selected)'}"
                    TextWrapping="Wrap"
                    TextAlignment="Center" />
                <Button
                    HorizontalAlignment="Center"
                    Content="Browse for ISO..."
                    IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource NotConverter}}"
                    Click="OnBrowseClicked" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ComboBox
                Grid.Column="0"
                Header="Target USB drive"
                HorizontalAlignment="Stretch"
                ItemsSource="{x:Bind ViewModel.Drives, Mode=OneWay}"
                SelectedItem="{x:Bind ViewModel.SelectedDrive, Mode=TwoWay}"
                IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource NotConverter}}">
                <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="services:DiskInfo">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE88E;" FontSize="14" />
                            <TextBlock>
                                <Run Text="Disk" />
                                <Run Text="{x:Bind Number}" />
                                <Run Text=" — " />
                                <Run Text="{x:Bind FriendlyName}" />
                                <Run Text=" (" />
                                <Run Text="{x:Bind SizeDisplay}" />
                                <Run Text=")" />
                            </TextBlock>
                        </StackPanel>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <Button
                Grid.Column="1"
                VerticalAlignment="Bottom"
                ToolTipService.ToolTip="Refresh drive list"
                Command="{x:Bind ViewModel.RefreshDrivesCommand}">
                <FontIcon Glyph="&#xE72C;" FontSize="14" />
            </Button>
        </Grid>

        <StackPanel
            Grid.Row="2"
            Orientation="Horizontal"
            Spacing="8">
            <Button
                Style="{StaticResource AccentButtonStyle}"
                Content="Start"
                Command="{x:Bind ViewModel.StartCommand}"
                IsEnabled="{x:Bind ViewModel.CanStart, Mode=OneWay}" />
            <Button
                Content="Cancel"
                Command="{x:Bind ViewModel.CancelCommand}"
                IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay}" />
        </StackPanel>

        <StackPanel Grid.Row="3" Spacing="4">
            <ProgressBar
                Minimum="0"
                Maximum="100"
                Value="{x:Bind ViewModel.ProgressPercent, Mode=OneWay}"
                ShowError="False"
                IsIndeterminate="False" />
            <TextBlock
                Style="{StaticResource CaptionTextBlockStyle}"
                Text="{x:Bind ViewModel.CurrentOperation, Mode=OneWay}"
                TextWrapping="Wrap" />
            <TextBlock
                Style="{StaticResource BodyStrongTextBlockStyle}"
                Text="{x:Bind ViewModel.Result, Mode=OneWay}"
                Visibility="{x:Bind ViewModel.Result, Mode=OneWay, Converter={StaticResource NullToCollapsedConverter}}"
                TextWrapping="Wrap" />
        </StackPanel>

        <Expander
            Grid.Row="4"
            Header="Log"
            HorizontalAlignment="Stretch"
            HorizontalContentAlignment="Stretch"
            IsExpanded="False">
            <ScrollViewer MaxHeight="260" VerticalScrollMode="Auto">
                <ItemsControl ItemsSource="{x:Bind ViewModel.LogLines, Mode=OneWay}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <TextBlock
                                FontFamily="Consolas"
                                FontSize="12"
                                Text="{x:Bind}"
                                TextWrapping="Wrap" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Expander>

        <TextBlock
            Grid.Row="5"
            VerticalAlignment="Bottom"
            Style="{StaticResource CaptionTextBlockStyle}"
            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
            Text="Runs as administrator. Target USB will be wiped. MIT-licensed." />
    </Grid>
</Page>

